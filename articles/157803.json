  "noiDung": "<table class=\"detailcontent\" width=\"100%\" border=\"0\" id=\"content\">\r\n                <tr>\r\n                    <td colspan=\"3\">\r\n                        <div align=\"justify\">\r\n                            <table border=\"0\" cellpadding=\"0\" cellspacing=\"0\" style=\"max-width:100%;color:rgb(0, 0, 0);font-family:Arial, Helvetica, sans-serif;\">\n\t<tbody style=\"max-width:100%;\">\n\t\t<tr style=\"max-width:100%;\">\n\t\t\t<td style=\"max-width:100%;width:167.4pt;padding:0in 5.4pt;\" valign=\"top\" width=\"223\">\n\t\t\t\t<p align=\"center\" style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;text-align:center;\">\n\t\t\t\t\t<b style=\"max-width:100%;\"><span lang=\"VI\" style=\"max-width:100%;background-color:unset !important;\">HỘI ĐỒNG NHÂN DÂN</span></b><br style=\"max-width:100%;\">\n\t\t\t\t\t<b style=\"max-width:100%;\">TỈNH KHÁNH HÒA<br style=\"max-width:100%;\">\n\t\t\t\t\t-------</b></p>\n\t\t\t</td>\n\t\t\t<td style=\"max-width:100%;width:275.4pt;padding:0in 5.4pt;\" valign=\"top\" width=\"367\">\n\t\t\t\t<p align=\"center\" style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;text-align:center;\">\n\t\t\t\t\t<b style=\"max-width:100%;\">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM<br style=\"max-width:100%;\">\n\t\t\t\t\tĐộc lập - Tự do - Hạnh phúc<br style=\"max-width:100%;\">\n\t\t\t\t\t---------------</b></p>\n\t\t\t</td>\n\t\t</tr>\n\t\t<tr style=\"max-width:100%;\">\n\t\t\t<td style=\"max-width:100%;width:167.4pt;padding:0in 5.4pt;\" valign=\"top\" width=\"223\">\n\t\t\t\t<p align=\"center\" style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;text-align:center;\">\n\t\t\t\t\t<span lang=\"VI\" style=\"max-width:100%;background-color:unset !important;\">Số: </span>10<span lang=\"VI\" style=\"max-width:100%;background-color:unset !important;\">/2022/NQ-HĐN</span>D</p>\n\t\t\t</td>\n\t\t\t<td style=\"max-width:100%;width:275.4pt;padding:0in 5.4pt;\" valign=\"top\" width=\"367\">\n\t\t\t\t<p align=\"right\" style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;text-align:right;\">\n\t\t\t\t\t<i style=\"max-width:100%;\">Khánh Hòa, ngày 23 tháng 9 năm 2022</i></p>\n\t\t\t</td>\n\t\t</tr>\n\t</tbody>\n</table>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<span lang=\"VI\" style=\"max-width:100%;background-color:unset !important;\"> </span></p>\n<p align=\"center\" style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;text-align:center;\">\n\t<b style=\"max-width:100%;\"><span lang=\"VI\" style=\"max-width:100%;font-size:12pt;background-color:unset !important;\">NGHỊ QUYẾT</span></b></p>\n<p align=\"center\" style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;text-align:center;\">\n\t<span lang=\"VI\" style=\"max-width:100%;background-color:unset !important;\">VỀ QUY ĐỊNH VIỆC SỬ DỤNG NGÂN SÁCH ĐỊA PHƯƠNG ĐỂ THỰC HIỆN CÔNG TÁC ĐIỀU TRA, KHẢO SÁT, ĐO ĐẠC, KIỂM ĐẾM, XÁC MINH NGUỒN GỐC ĐẤT, TÀI SẢN GẮN LIỀN VỚI ĐẤT KHI NHÀ NƯỚC THU HỒI ĐẤT TẠI KHU KINH TẾ VÂN PHONG VÀ HUYỆN CAM LÂM, TỈNH KHÁNH HÒA</span></p>\n<p align=\"center\" style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;text-align:center;\">\n\t<b style=\"max-width:100%;\"><span lang=\"VI\" style=\"max-width:100%;font-size:12pt;background-color:unset !important;\">HỘI ĐỒNG NHÂN DÂN TỈNH KHÁNH HÒA<br style=\"max-width:100%;\">\n\tKHÓA VII, KỲ HỌP CHUYÊN ĐỀ</span></b></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<i style=\"max-width:100%;\">Căn cứ Luật Tổ chức chính quyền địa phương ngày 19 tháng 6 năm 2015;</i></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<i style=\"max-width:100%;\">Căn cứ Luật Sửa đổi, bổ sung một số điều của Luật Tổ chức chính phủ và Luật Tổ chức chính quyền địa phương ngày 22 tháng 11 năm 2019;</i></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<i style=\"max-width:100%;\">Căn cứ Luật Đất đai ngày 29 tháng 11 năm 2013;</i></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<i style=\"max-width:100%;\">Căn cứ Luật Ngân sách nhà nước ngày 25 tháng 6 năm 2015;</i></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<i style=\"max-width:100%;\">Căn cứ Luật Ban hành văn bản quy phạm pháp luật ngày 22 tháng 6 năm 2015;</i></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<i style=\"max-width:100%;\">Căn cứ Luật Sửa đổi, bổ sung một số điều của Luật Ban hành văn bản quy phạm pháp luật ngày 18 tháng 6 năm 2020;</i></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<i style=\"max-width:100%;\">Căn cứ Nghị quyết số 55/2Q22/QH15 ngày 16 tháng 6 năm 2022 của Quốc hội về thí điểm một số cơ chế, chính sách đặc thù phát triển tỉnh Khánh Hòa;</i></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<i style=\"max-width:100%;\">Căn cứ Nghị định số <a class=\"text-blue\" href=\"https://thuvienphapluat.vn/van-ban/bat-dong-san/nghi-dinh-43-2014-nd-cp-huong-dan-thi-hanh-luat-dat-dai-230680.aspx\" style=\"margin:0px;padding-left:0px;padding-right:0px;color:rgb(14, 112, 195);text-decoration-line:none;cursor:pointer;max-width:100%;\" target=\"_blank\" title=\"Nghị định 43/2014/NĐ-CP\">43/2014/NĐ-CP</a> ngày 15 tháng 5 năm 2014 của Chính phủ quy định chi tiết thi hành một số điều Luật Đất đai;</i></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<i style=\"max-width:100%;\">Căn cứ Nghị định số <a class=\"text-blue\" href=\"https://thuvienphapluat.vn/van-ban/bat-dong-san/nghi-dinh-47-2014-nd-cp-boi-thuong-ho-tro-tai-dinh-cu-khi-nha-nuoc-thu-hoi-dat-230624.aspx\" style=\"margin:0px;padding-left:0px;padding-right:0px;color:rgb(14, 112, 195);text-decoration-line:none;cursor:pointer;max-width:100%;\" target=\"_blank\" title=\"Nghị định 47/2014/NĐ-CP\">47/2014/NĐ-CP</a> ngày 15 tháng 5 năm 2014 của Chính phủ quy định về bồi thường, hỗ trợ, tái định cư khi Nhà nước thu hồi đất;</i></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<i style=\"max-width:100%;\">Căn cứ Nghị định số <a class=\"text-blue\" href=\"https://thuvienphapluat.vn/van-ban/tai-chinh-nha-nuoc/nghi-dinh-163-2016-nd-cp-huong-dan-luat-ngan-sach-nha-nuoc-335331.aspx\" style=\"margin:0px;padding-left:0px;padding-right:0px;color:rgb(14, 112, 195);text-decoration-line:none;cursor:pointer;max-width:100%;\" target=\"_blank\" title=\"Nghị định 163/2016/NĐ-CP\">163/2016/NĐ-CP</a> ngày 21 tháng 12 năm 2016 của Chính phủ quy định chi tiết thi hành một số điều của Luật Ngân sách nhà nước;</i></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<i style=\"max-width:100%;\">Căn cứ Nghị định số <a class=\"text-blue\" href=\"https://thuvienphapluat.vn/van-ban/bat-dong-san/nghi-dinh-01-2017-nd-cp-sua-doi-nghi-dinh-huong-dan-luat-dat-dai-337031.aspx\" style=\"margin:0px;padding-left:0px;padding-right:0px;color:rgb(14, 112, 195);text-decoration-line:none;cursor:pointer;max-width:100%;\" target=\"_blank\" title=\"Nghị định 01/2017/NĐ-CP\">01/2017/NĐ-CP</a> ngày 06 tháng 01 năm 2017 của Chính phủ về việc sửa đổi, bổ sung một số quy định chi tiết thi hành Luật Đất đai;</i></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<i style=\"max-width:100%;\">Xét Tờ trình số 8435/TTr-UBND ngày 08 tháng 9 năm 2022 của Ủy ban nhân dân tỉnh; Báo cáo thẩm tra số 118/BC-HĐND ngày 20 tháng 9 năm 2022 của Ban Pháp chế Hội đồng nhân dân tỉnh; ý kiến thảo luận của đại biểu Hội đồng nhân dân tỉnh tại kỳ họp.</i></p>\n<p align=\"center\" style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;text-align:center;\">\n\t<b style=\"max-width:100%;\"><span lang=\"VI\" style=\"max-width:100%;font-size:12pt;background-color:unset !important;\">QUYẾT NGHỊ:</span></b></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<b style=\"max-width:100%;\">Điều 1. Phạm vi điều chỉnh</b></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<span lang=\"VI\" style=\"max-width:100%;background-color:unset !important;\">Nghị quyết này quy định nguồn kinh phí để thực hiện việc điều tra, khảo sát, đo đạc, kiểm đếm, xác minh nguồn gốc đất, tài sản gắn liền với đất trước khi cơ quan nhà nước có thẩm quyền ban hành thông báo thu hồi đất đối với các dự án xây dựng khu công nghiệp, khu chế xuất, khu công nghệ cao, khu kinh tế; khu đô thị, khu dân cư nông thôn mới; khu sản xuất, chế biến nông sản, lâm sản, thủy sản, hải sản tập trung sử dụng vốn ngoài ngân sách nhà nước thuộc trường hợp Nhà nước thu hồi đất theo quy định của pháp luật về đất đai và có quy mô từ 300 ha trở lên tại Khu kinh tế Vân Phong và huyện Cam Lâm, tỉnh Khánh Hòa.</span></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<b style=\"max-width:100%;\">Điều 2. Đối tượng áp dụng</b></p>\n<p style=\"margin:6pt 0px;padding-left:0px;padding-right:0px;line-height:15.6px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<span lang=\"VI\" style=\"max-width:100%;background-color:unset !important;\">1. Ban Quản lý Khu kinh tế Vân Phong;</span></p>\n<div class=\"viewAds-317\" style=\"margin:0px;padding-left:0px;padding-right:0px;max-width:100%;font-family:Arial, Helvetica, sans-serif;\">\n\t<div style=\"margin:0px;padding-left:0px;padding-right:0px;max-width:100%;clear:both;\">\n\t\t </div>\n\t<div id=\"mboustreamthuvienphapluatvn-dxOwdkpYgK\" style=\"margin:0px;padding-left:0px;padding-right:0px;max-width:100%;\">\n\t\t<div class=\"gliaplayer-container styles-module_container_xuywD\" data-gc-boot-time=\"2025-08-22T03:06:20.941Z\" data-gc-donotuse-internal-id=\"slot-element\" data-gc-instream-style-scope=\"\" data-gc-slot-occupied=\"\" data-gc-test-id=\"gc-instream-slot\" data-slot=\"thuvienphapluat_desktop\" style=\"color:unset !important;font:unset  !important;text-rendering:unset !important;writing-mode:unset !important;zoom:unset !important;alignment-baseline:unset !important;backface-visibility:unset !important;background:unset !important;baseline-shift:unset !important;border:unset !important;border-radius:unset !important;border-collapse:unset !important;box-shadow:unset  !important;box-sizing:unset !important;caption-side:unset !important;clear:both !important;clip:unset !important;clip-path:unset !important;clip-rule:unset !important;color-interpolation:unset !important;color-interpolation-filters:unset !important